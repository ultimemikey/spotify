              <div class="radio-circle" style="background:linear-gradient(135deg,#fde047,#f59e0b,#d97706);"></div>
              <div class="radio-artist-name">Mia Guisse</div>
            </div>
            <p class="radio-desc">Avec AMADEUS, Viviane Chidid, Jeeba et bien...</p>
          </div>

          <!-- Khalid -->
          <div class="radio-card" id="card-khalid">
            <div class="radio-art" style="background:linear-gradient(155deg,#fb923c 0%,#dc2626 40%,#7f1d1d 100%);">
              <div class="radio-art-top">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white" opacity=".9">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
                <span class="radio-label">RADIO</span>
              </div>
              <div class="radio-circle" style="background:linear-gradient(135deg,#fca5a5,#ef4444,#b91c1c);"></div>
              <div class="radio-artist-name">Khalid</div>
            </div>
            <p class="radio-desc">Avec Ruma, Dababy, Zayn et bien d'autres artistes</p>
          </div>

        </div>
      </section>

      <!-- ─── Artistes populaires ────────────────── -->
      <section class="section">
        <div class="section-head">
          <h2 class="section-title">Artistes populaires</h2>
          <a class="section-link" href="#">Tout afficher</a>
        </div>
        <div class="artist-grid">

          <div class="artist-card" id="artist-amadeus">
            <div class="artist-img" style="background:linear-gradient(155deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);"></div>
            <div class="artist-name">AMADEUS</div>
            <div class="artist-sub">Artiste</div>
          </div>

          <div class="artist-card" id="artist-mia">
            <div class="artist-img" style="background:linear-gradient(155deg,#fde68a 0%,#84cc16 50%,#166534 100%);"></div>
            <div class="artist-name">Mia Guisse</div>
            <div class="artist-sub">Artiste</div>
          </div>

          <div class="artist-card" id="artist-vj">
            <div class="artist-img" style="background:linear-gradient(155deg,#bfdbfe 0%,#3b82f6 50%,#1e40af 100%);"></div>
            <div class="artist-name">VJ</div>
            <div class="artist-sub">Artiste</div>
          </div>

          <div class="artist-card" id="artist-wally">
            <div class="artist-img" style="background:linear-gradient(155deg,#fde68a 0%,#f59e0b 50%,#92400e 100%);"></div>
            <div class="artist-name">Wally B. Seck</div>
            <div class="artist-sub">Artiste</div>
          </div>

          <div class="artist-card" id="artist-dadju">
            <div class="artist-img" style="background:linear-gradient(155deg,#f0fdf4 0%,#4ade80 50%,#15803d 100%);"></div>
            <div class="artist-name">Dadju</div>
            <div class="artist-sub">Artiste</div>
          </div>

          <div class="artist-card" id="artist-tiakola">
            <div class="artist-img" style="background:linear-gradient(155deg,#fca5a5 0%,#ef4444 50%,#7f1d1d 100%);"></div>
            <div class="artist-name">Tiakola</div>
            <div class="artist-sub">Artiste</div>
          </div>

        </div>
      </section>

    </main>
  </div>

  <!-- ══════════════════════ PLAYER BAR ══════════════════════ -->
  <div class="playerbar">

    <!-- Left: track info -->
    <div class="player-left">
      <div class="player-art" style="background:linear-gradient(135deg,#374151,#111827);"></div>
      <div class="player-track">
        <span class="player-track-name" id="player-track-name">--</span>
        <span class="player-track-artist" id="player-track-artist">--</span>
      </div>
      <button class="player-heart" id="player-like" title="Ajouter aux titres likés">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
        </svg>
      </button>
    </div>

    <!-- Center: controls + progress -->
    <div class="player-center">
      <div class="player-controls">
        <!-- Shuffle -->
        <button class="ctrl-btn" id="btn-shuffle" title="Lecture aléatoire">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.83 13.83l1.94-1.94-1.94-1.94L16.25 8.5l3.25 3.5-3.25 3.5-1.42-1.67zm-5.66 0L7.23 11.89l1.94-1.94L7.75 8.5 4.5 12l3.25 3.5 1.42-1.67zm8.66-9.5l-1.41 1.41.94.94-3.03 3.03-2.85-2.85-4.62 4.64 1.41 1.41 3.21-3.22 2.85 2.86 4.44-4.43.93.93 1.41-1.41L17.83 4.33z"/>
          </svg>
        </button>
        <!-- Previous -->
        <button class="ctrl-btn" id="btn-prev" title="Précédent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/>
          </svg>
        </button>
        <!-- Play / Pause -->
        <button class="ctrl-play" id="btn-play" title="Lecture">
          <svg id="icon-play" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
        <!-- Next -->
        <button class="ctrl-btn" id="btn-next" title="Suivant">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zm6.5-3.86v12h2V6h-2z"/>
          </svg>
        </button>
        <!-- Repeat -->
        <button class="ctrl-btn" id="btn-repeat" title="Répéter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
          </svg>
        </button>
      </div>

      <!-- Progress bar -->
      <div class="player-progress">
        <span class="p-time" id="player-current">-:--</span>
        <div class="p-bar" id="p-bar">
          <div class="p-fill" id="p-fill" style="width:0%;"></div>
        </div>
        <span class="p-time" id="player-total">-:--</span>
      </div>
    </div>

    <!-- Right: extras -->
    <div class="player-right">
      <!-- Queue -->
      <button class="ctrl-btn" title="File d'attente" id="btn-queue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M15 6H3v2h12V6zm0 4H3v2h12v-2zM3 16h8v-2H3v2zM17 6v8.18c-.31-.11-.65-.18-1-.18-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3V8h3V6h-5z"/>
        </svg>
      </button>
      <!-- Device -->
      <button class="ctrl-btn" title="Se connecter à un appareil" id="btn-device">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4 6h18V4H4c-1.1 0-2 .9-2 2v11H0v3h14v-3H4V6zm19 2h-6c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h6c.55 0 1-.45 1-1V9c0-.55-.45-1-1-1zm-1 9h-4v-7h4v7z"/>
        </svg>
      </button>
      <!-- Volume -->
      <button class="ctrl-btn" title="Son" id="btn-volume">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
      <!-- Volume bar -->
      <div class="vol-bar" id="vol-bar" title="Volume">
        <div class="vol-fill" id="vol-fill"></div>
      </div>
      <!-- Expand -->
      <button class="ctrl-btn" title="Plein écran" id="btn-fullscreen">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/>
        </svg>
      </button>
    </div>
  </div>

</div>
